# Copy to a local shell/session before running k6. Do not commit real secrets.

# Default is local/staging. Production is blocked unless ALLOW_PRODUCTION_LOAD_TEST=true.
BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000

# Use only after explicit approval for a watched production smoke.
# ALLOW_PRODUCTION_LOAD_TEST=true

# Smoke defaults are intentionally tiny.
SMOKE_VUS=3
SMOKE_DURATION=90s
BOT_GUARD_DURATION=30s

# Staged profiles: small, medium, large, target.
TEST_PROFILE=small

# Optional authenticated scenario support. Prefer a staging test account/session.
# Never hardcode real credentials in scripts or docs.
# AUTH_TOKEN=
# SESSION_COOKIE=
